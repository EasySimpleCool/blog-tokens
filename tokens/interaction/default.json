{
  "modify": {
    "interaction": {
      "color": {
        "accent": {
          "fill": {
            "$type": "color",
            "$value": "{modify.accent.color.primary}"
          },
          "fill-05": {
            "$type": "color",
            "$value": "{modify.accent.color.primary-02}"
          },
          "stroke": {
            "$type": "color",
            "$value": "{modify.accent.color.primary}"
          }
        },
        "fg": {
          "text": {
            "$type": "color",
            "$value": "{modify.accent.color.on-accent}"
          },
          "text-alt": {
            "$type": "color",
            "$value": "{modify.accent.color.on-accent-alt}"
          }
        },
        "bg": {
          "fill": {
            "$type": "color",
            "$value": "{modify.displaymode.color.bg.above.default}"
          },
          "stroke": {
            "$type": "color",
            "$value": "{modify.displaymode.color.stroke.default}"
          }
        }
      },
      "shadow": {
        "$type": "boxShadow",
        "$value": [
          {
            "x": "{modify.interaction.number.shadow.1.x}",
            "y": "{modify.interaction.number.shadow.1.y}",
            "blur": "{modify.interaction.number.shadow.1.blur}",
            "spread": "{modify.interaction.number.shadow.1.spread}",
            "color": "{input.color.shadow.medium.1}",
            "type": "dropShadow"
          },
          {
            "x": "{modify.interaction.number.shadow.2.x}",
            "y": "{modify.interaction.number.shadow.2.y}",
            "blur": "{modify.interaction.number.shadow.2.blur}",
            "spread": "{modify.interaction.number.shadow.2.spread}",
            "color": "{input.color.shadow.medium.2}",
            "type": "dropShadow"
          },
          {
            "x": "{modify.interaction.number.shadow.3.x}",
            "y": "{modify.interaction.number.shadow.3.y}",
            "blur": "{modify.interaction.number.shadow.3.blur}",
            "spread": "{modify.interaction.number.shadow.3.spread}",
            "color": "",
            "type": "dropShadow"
          }
        ]
      },
      "dimension": {
        "stroke": {
          "$type": "dimension",
          "$value": "1px"
        }
      },
      "number": {
        "shadow": {
          "1": {
            "x": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.1.x}"
            },
            "y": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.1.y}"
            },
            "blur": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.1.blur}"
            },
            "spread": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.1.spread}"
            }
          },
          "2": {
            "x": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.2.x}"
            },
            "y": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.2.y}"
            },
            "blur": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.2.blur}"
            },
            "spread": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.2.spread}"
            }
          },
          "3": {
            "x": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.3.x}"
            },
            "y": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.3.y}"
            },
            "blur": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.3.blur}"
            },
            "spread": {
              "$type": "number",
              "$value": "{input.number.shadow.medium.3.spread}"
            }
          }
        }
      },
      "text": {
        "$type": "text",
        "$value": "Default"
      }
    }
  }
}