{
  "comp": {
    "button": {
      "bg": {
        "$type": "color",
        "$value": "{modify.button.variant.bg}"
      },
      "fg": {
        "$type": "color",
        "$value": "{modify.button.variant.fg}"
      },
      "stroke": {
        "$type": "color",
        "$value": "{modify.button.variant.stroke}"
      },
      "min-h": {
        "$type": "dimension",
        "$value": "64px"
      },
      "b-rad": {
        "$type": "dimension",
        "$value": "{modify.button.size.b-rad}"
      },
      "pad": {
        "$type": "dimension",
        "$value": "{modify.button.size.dimension}"
      },
      "gap": {
        "$type": "dimension",
        "$value": "{output.dimension.fixed-8}"
      },
      "stroke-w": {
        "$type": "dimension",
        "$value": "{modify.interaction.dimension.stroke}"
      }
    }
  }
}