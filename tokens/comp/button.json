{
  "comp": {
    "button": {
      "bg": {
        "$type": "color",
        "$value": "{output.color.accent.primary}"
      },
      "fg": {
        "$type": "color",
        "$value": "{modify.interaction.color.fg.text}"
      },
      "stroke": {
        "$type": "color",
        "$value": "{output.color.accent.stroke}"
      },
      "min-h": {
        "$type": "dimension",
        "$value": "64px"
      },
      "b-rad": {
        "$type": "dimension",
        "$value": "{output.border-radius.default}"
      },
      "pad": {
        "$type": "dimension",
        "$value": "{output.dimension.fixed-16}"
      },
      "stroke-w": {
        "$type": "dimension",
        "$value": "{modify.interaction.dimension.stroke}"
      }
    }
  }
}