{
  "comp": {
    "post-preview": {
      "bg": {
        "fill": {
          "$type": "color",
          "$value": "{modify.interaction.color.bg.fill}"
        },
        "stroke": {
          "$type": "color",
          "$value": "{modify.interaction.color.bg.stroke}"
        }
      },
      "b-rad": {
        "$type": "dimension",
        "$value": "{output.border-radius.default}"
      },
      "pad": {
        "$type": "dimension",
        "$value": "{output.dimension.fluid-md}"
      },
      "gap": {
        "$type": "dimension",
        "$value": "{output.dimension.fixed-16}"
      },
      "stroke-w": {
        "$type": "dimension",
        "$value": "{modify.interaction.dimension.stroke}"
      },
      "shadow": {
        "$type": "boxShadow",
        "$value": "{modify.interaction.shadow}"
      }
    }
  }
}